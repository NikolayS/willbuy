{
  "name": "willbuy",
  "private": true,
  "version": "0.0.0",
  "description": "willbuy.dev monorepo — see SPEC.md",
  "type": "module",
  "engines": {
    "bun": ">=1.1"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "build": "bun run --filter '*' build",
    "lint": "eslint .",
    "typecheck": "tsc -b --pretty && bun run --filter '*' typecheck",
    "test": "vitest run --passWithNoTests && bun run --filter '*' test",
    "format": "prettier --write .",
    "migrate": "bash scripts/migrate.sh"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.2",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vitest": "^2.1.8"
  }
}
