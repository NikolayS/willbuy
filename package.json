{
  "name": "willbuy",
  "private": true,
  "version": "0.0.0",
  "description": "willbuy.dev monorepo — see SPEC.md",
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
