{
  "name": "@willbuy/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Shared zod schemas + scoring weights for willbuy.dev (visitor output, backstory, scoreVisit).",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./visitor": {
      "types": "./src/visitor.ts",
      "default": "./src/visitor.ts"
    },
    "./scoring": {
      "types": "./src/scoring.ts",
      "default": "./src/scoring.ts"
    },
    "./backstory": {
      "types": "./src/backstory.ts",
      "default": "./src/backstory.ts"
    },
    "./report": {
      "types": "./src/report.ts",
      "default": "./src/report.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "vitest": "^2.1.8",
    "typescript": "^5.7.2"
  }
}
