{
  "name": "@willbuy/capture-worker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Hardened-container Playwright capture: navigates a URL, extracts a11y tree, enforces resource ceilings (spec §2 #2 + §2 #6).",
  "main": "src/capture.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit --pretty",
    "test": "vitest run --exclude test/smoke.test.ts",
    "test:integration": "vitest run test/integration.test.ts",
    "smoke": "vitest run test/smoke.test.ts"
  },
  "dependencies": {
    "@willbuy/log": "workspace:*",
    "pg": "^8.20.0",
    "pino": "^9.5.0",
    "playwright": "1.45.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "@willbuy/capture-broker": "workspace:*",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "zod": "^3.23.0"
  }
}
