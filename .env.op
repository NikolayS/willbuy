# .env.op — 1Password references. Safe to commit (no values).
# Usage:
#   op run --env-file=.env.op -- <command>
# Examples:
#   op run --env-file=.env.op -- scripts/push-secrets.sh
#   op run --env-file=.env.op -- docker compose up -d
#
# Requires: OP_ACCOUNT=my.1password.com (already persisted in ~/.zshrc).

